<% layout("../layouts/boilerplate.ejs") %>
<link rel="stylesheet" href="/stylesheets/listings/index.css">

<div class="search-container">
    <form class="search-form" action="/listings" method="GET">
        <div class="search-input-wrapper">
            <input type="text" id="searchInput" name="search" placeholder="Search destinations" value="<%= typeof search !== 'undefined' ? search : '' %>">
            <button type="button" id="clearSearch" class="clear-btn">
                &times;
            </button>
        </div>
        <button type="submit" class="search-btn">
            <i class="fa-solid fa-magnifying-glass"></i>
            Search
        </button>
    </form>
</div>

<div class="container">

    <% if(allListings.length > 0)   { %>
        <h1 class="page-title">
            <%= search ? `Search Results for "${search}"` : "All Listings" %>
        </h1>
    <% } %>

    <div class="content-layout">
        <aside class="filter-sidebar">
            <form action="/listings" method="GET">
                <input type="hidden" name="search" value="<%= search || '' %>">
                <h3>Property Type</h3>
                <label>
                    <input type="radio" name="propertyType" value="Hotel" <%= filters.propertyType === "Hotel" ? "checked" : "" %>>Hotel
                </label>
                <label>
                    <input type="radio" name="propertyType" value="Apartment" <%= filters.propertyType === "Apartment" ? "checked" : "" %>>Apartment
                </label>
                <label>
                    <input type="radio" name="propertyType" value="Villa" <%= filters.propertyType === "Villa" ? "checked" : "" %>>Villa
                </label>
                <label>
                    <input type="radio" name="propertyType" value="Homestay" <%= filters.propertyType === "Homestay" ? "checked" : "" %>>Homestay
                </label>
                <label>
                    <input type="radio" name="propertyType" value="Hostel" <%= filters.propertyType === "Hostel" ? "checked" : "" %>>Hostel
                </label>
                <label>
                    <input type="radio" name="propertyType" value="Resort" <%= filters.propertyType === "Resort" ? "checked" : "" %>>Resort
                </label>
                <label>
                    <input type="radio" name="propertyType" value="Guest House" <%= filters.propertyType === "Guest House" ? "checked" : "" %>>Guest House
                </label>

                <h3>Amenities</h3>
                
                <label>
                    <input type="checkbox" name="wifi" value="true" <%= filters.wifi === "true" ? "checked" : "" %>>Wifi
                </label>
                <label>
                    <input type="checkbox" name="parking" value="true" <%= filters.parking === "true" ? "checked" : "" %>>Parking
                </label>
                <label>
                    <input type="checkbox" name="spa" value="true" <%= filters.spa === "true" ? "checked" : "" %>>Spa
                </label>
                <label>
                    <input type="checkbox" name="pool" value="true" <%= filters.pool === "true" ? "checked" : "" %>>Pool
                </label>
                <label>
                    <input type="checkbox" name="gym" value="true" <%= filters.gym === "true" ? "checked" : "" %>>Gym
                </label>
                <label>
                    <input type="checkbox" name="airConditioning" value="true" <%= filters.airConditioning === "true" ? "checked" : "" %>>Air Conditioning
                </label>
                <label>
                    <input type="checkbox" name="breakfast" value="true" <%= filters.breakfast === "true" ? "checked" : "" %>>Breakfast
                </label>
                <label>
                    <input type="checkbox" name="petFriendly" value="true" <%= filters.petFriendly === "true" ? "checked" : "" %>>Pet Friendly
                </label>
                <label>
                    <input type="checkbox" name="laundryService" value="true" <%= filters.laundryService === "true" ? "checked" : "" %>>Laundry Service
                </label>
                <label>
                    <input type="checkbox" name="restaurant" value="true" <%= filters.restaurant === "true" ? "checked" : "" %>>Restaurant
                </label>
                <label>
                    <input type="checkbox" name="kitchen" value="true" <%= filters.kitchen === "true" ? "checked" : "" %>>Kitchen
                </label>
                <label>
                    <input type="checkbox" name="bar" value="true" <%= filters.bar === "true" ? "checked" : "" %>>Bar
                </label>
                <label>
                    <input type="checkbox" name="roomService" value="true" <%= filters.roomService === "true" ? "checked" : "" %>>Room Service
                </label>
                <label>
                    <input type="checkbox" name="frontDesk" value="true" <%= filters.frontDesk === "true" ? "checked" : "" %>>FrontDesk
                </label>

                <h3>Price</h3>

                <input type="number" name="minPrice" placeholder="Min Price" value="<%= filters.minPrice || '' %>">
                <input type="number" name="maxPrice" placeholder="Max price" value="<%= filters.maxPrice || '' %>">
                <button type="submit">Apply Filters</button>
                <button type="button" id="clearFiltersBtn">Clear Filters</button>
            </form>
        </aside>
        <section class="listings-section">
            <% if(allListings.length === 0) { %>
                <div class="no-results">
                    <h3>No listings found</h3>
                    <% if(search) {%>
                        <p>No results found for "<%= search %>"</p>
                    <% } %>
                </div>
            <% } %>
            
            <div class="listings">
                <% allListings.forEach(listing => { %>
                    <div class="listing-wrapper">
                        <% const isWishlisted = wishlist && wishlist.includes(listing._id.toString()); %>
                        <button class="wishlist-btn" data-id="<%= listing._id %>">
                            <i class="fa-<%= isWishlisted ? 'solid' : 'regular' %> fa-heart"></i>
                        </button>
                        <a href="/listings/<%= listing._id %>" style="text-decoration: none; color: inherit;">
                            <div class="listing-card">
                                <img src="<%= listing.images[0].url %>" alt="image">
                                <div class="card-body">
                                    <h2><%= listing.title %></h2>
                                    <p>Owned by: <%= listing.owner.username %></p>
                                    <p>Starting from $ <%= listing.startingPrice %> / night</p>
                                    <p><%= listing.location.city %>, <%= listing.location.country %></p>
                                </div>
                            </div>
                        </a>
                    </div>
                <% }) %>
            </div>
        </section>
    </div>
    
    <div id="toast"></div>
</div>

<script src="/scripts/listings/index.js"></script>