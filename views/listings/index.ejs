<% layout("../layouts/boilerplate.ejs") %>
<link rel="stylesheet" href="/stylesheets/listings/index.css">

<div class="search-container">
    <form class="search-form" action="/listings" method="GET">
        <div class="search-input-wrapper">
            <input type="text" id="searchInput" name="search" placeholder="Search destinations" value="<%= typeof search !== 'undefined' ? search : '' %>">
            <button type="button" id="clearSearch" class="clear-btn">
                &times;
            </button>
        </div>
        <button type="submit" class="search-btn">
            <i class="fa-solid fa-magnifying-glass"></i>
            Search
        </button>
    </form>
</div>

<div class="container">

    <% if(allListings.length > 0)   { %>
        <h1 class="page-title">
            <%= search ? `Search Results for "${search}"` : "All Listings" %>
        </h1>
    <% } %>

    <button class="mobile-filter-btn" id="mobileFilterBtn">
        <i class="bi bi-sliders"></i>
        Filters
    </button>

    <div class="content-layout">
        <aside class="filter-sidebar">
            <form action="/listings" method="GET">
                <input type="hidden" name="search" value="<%= search || '' %>">
                <h3>Property Type</h3>
                <div class="filter-grid">
                    <label class="filter-card">
                        <input type="radio" name="propertyType" value="Hotel" <%= filters.propertyType === "Hotel" ? "checked" : "" %>>
                        <i class="bi bi-building"></i>
                        <span>Hotel</span>
                    </label>
                    <label class="filter-card">
                        <input type="radio" name="propertyType" value="Apartment" <%= filters.propertyType === "Apartment" ? "checked" : "" %>>
                        <i class="bi bi-house-door"></i>
                        <span>Apartment</span>
                    </label>
                    <label class="filter-card">
                        <input type="radio" name="propertyType" value="Villa" <%= filters.propertyType === "Villa" ? "checked" : "" %>>
                        <i class="bi bi-house-heart"></i>
                        <span>Villa</span>
                    </label>
                    <label class="filter-card">
                        <input type="radio" name="propertyType" value="Homestay" <%= filters.propertyType === "Homestay" ? "checked" : "" %>>
                        <i class="bi bi-house"></i>
                        <span>Homestay</span>
                    </label>
                    <label class="filter-card">
                        <input type="radio" name="propertyType" value="Hostel" <%= filters.propertyType === "Hostel" ? "checked" : "" %>>
                        <i class="bi bi-people"></i>
                        <span>Hostel</span>
                    </label>
                    <label class="filter-card">
                        <input type="radio" name="propertyType" value="Resort" <%= filters.propertyType === "Resort" ? "checked" : "" %>>
                        <i class="bi bi-water"></i>
                        <span>Resort</span>
                    </label>
                    <label class="filter-card">
                        <input type="radio" name="propertyType" value="Guest House" <%= filters.propertyType === "Guest House" ? "checked" : "" %>>
                        <i class="bi bi-house-check"></i>
                        <span>Guest House</span>
                    </label>
                </div>
                
                <h3>Amenities</h3>
                
                <div class="filter-grid">
                    <label class="filter-card">
                        <input type="checkbox" name="wifi" value="true" <%= filters.wifi === "true" ? "checked" : "" %>>
                        <i class="bi bi-wifi"></i>
                        <span>Wifi</span>
                    </label>
                    <label class="filter-card">
                        <input type="checkbox" name="parking" value="true" <%= filters.parking === "true" ? "checked" : "" %>>
                        <i class="bi bi-car-front-fill"></i>
                        <span>Parking</span>
                    </label>
                    <label class="filter-card">
                        <input type="checkbox" name="spa" value="true" <%= filters.spa === "true" ? "checked" : "" %>>
                        <i class="bi bi-flower1"></i>
                        <span>Spa</span>
                    </label>
                    <label class="filter-card">
                        <input type="checkbox" name="pool" value="true" <%= filters.pool === "true" ? "checked" : "" %>>
                        <i class="bi bi-water"></i>
                        <span>Pool</span>
                    </label>
                    <label class="filter-card">
                        <input type="checkbox" name="gym" value="true" <%= filters.gym === "true" ? "checked" : "" %>>
                        <i class="bi bi-activity"></i>
                        <span>Gym</span>
                    </label>
                    <label class="filter-card">
                        <input type="checkbox" name="airConditioning" value="true" <%= filters.airConditioning === "true" ? "checked" : "" %>>
                        <i class="bi bi-snow"></i>
                        <span>Air Conditioning</span>
                    </label>
                    <label class="filter-card">
                        <input type="checkbox" name="breakfast" value="true" <%= filters.breakfast === "true" ? "checked" : "" %>>
                        <i class="bi bi-cup-hot"></i>
                        <span>Breakfast</span>
                    </label>
                    <label class="filter-card">
                        <input type="checkbox" name="petFriendly" value="true" <%= filters.petFriendly === "true" ? "checked" : "" %>>
                        <i class="bi bi-heart"></i>
                        <span>Pet Friendly</span>
                    </label>
                    <label class="filter-card">
                        <input type="checkbox" name="laundryService" value="true" <%= filters.laundryService === "true" ? "checked" : "" %>>
                        <i class="bi bi-basket2"></i>
                        <span>Laundry Service</span>
                    </label>
                    <label class="filter-card">
                        <input type="checkbox" name="restaurant" value="true" <%= filters.restaurant === "true" ? "checked" : "" %>>
                        <i class="bi bi-shop"></i>
                        <span>Restaurant</span>
                    </label>
                    <label class="filter-card">
                        <input type="checkbox" name="kitchen" value="true" <%= filters.kitchen === "true" ? "checked" : "" %>>
                        <i class="bi bi-egg-fried"></i>
                        <span>Kitchen</span>
                    </label>
                    <label class="filter-card">
                        <input type="checkbox" name="bar" value="true" <%= filters.bar === "true" ? "checked" : "" %>>
                        <i class="bi bi-cup-straw"></i>
                        <span>Bar</span>
                    </label>
                    <label class="filter-card">
                        <input type="checkbox" name="roomService" value="true" <%= filters.roomService === "true" ? "checked" : "" %>>
                        <i class="bi bi-bell"></i>
                        <span>Room Service</span>
                    </label>
                    <label class="filter-card">
                        <input type="checkbox" name="frontDesk" value="true" <%= filters.frontDesk === "true" ? "checked" : "" %>>
                        <i class="bi bi-person-workspace"></i>
                        <span>Front Desk</span>
                    </label>
                </div>
                
                <h3>Price</h3>

                <input type="number" name="minPrice" placeholder="Min Price" value="<%= filters.minPrice || '' %>">
                <input type="number" name="maxPrice" placeholder="Max price" value="<%= filters.maxPrice || '' %>">
                <button type="submit">Apply Filters</button>
                <button type="button" id="clearFiltersBtn">Clear Filters</button>
            </form>
        </aside>
        <section class="listings-section">
            <% if(allListings.length === 0) { %>
                <div class="no-results">
                    <h3>No listings found</h3>
                    <% if(search) {%>
                        <p>No results found for "<%= search %>"</p>
                    <% } %>
                </div>
            <% } %>
            
            <div class="listings">
                <% allListings.forEach(listing => { %>
                    <div class="listing-wrapper">
                        <% const isWishlisted = wishlist && wishlist.includes(listing._id.toString()); %>
                        <button class="wishlist-btn" data-id="<%= listing._id %>">
                            <i class="fa-<%= isWishlisted ? 'solid' : 'regular' %> fa-heart"></i>
                        </button>
                        <a href="/listings/<%= listing._id %>" style="text-decoration: none; color: inherit;">
                            <div class="listing-card">
                                <img src="<%= listing.images[0].url %>" alt="image">
                                <div class="card-body">
                                    <h2><%= listing.title %></h2>
                                    <p class="listing-location">
                                        <i class="bi bi-geo-alt-fill"></i>
                                        <%= listing.location.city %>, <%= listing.location.country %>
                                    </p>
                                    <p class="listing-price">
                                        Starting from $ <%= listing.startingPrice %><span>/night</span>
                                    </p>
                                </div>
                            </div>
                        </a>
                    </div>
                <% }) %>
            </div>
        </section>
    </div>
    
    <div id="toast"></div>
</div>

<script src="/scripts/listings/index.js"></script>