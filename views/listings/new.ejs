<% layout("../layouts/boilerplate.ejs") %>
<link rel="stylesheet" href="/stylesheets/listings/new.css">
<div class="form-container">
    <div class="listing-header">
        <h1>Create a New Stay</h1>
        <p>Share your property with travellers around the world</p>
    </div>
    <div class="form-card">
        <form method="POST" action="/listings" enctype="multipart/form-data">
            
            <div class="form-section">
                <div class="section-header">
                    <i class="bi bi-house-door"></i>
                    <h2>Basic Information</h2>
                </div>
                <div class="form-group">
                    <label>Property Title</label>
                    <input type="text" name="title" placeholder="Enter property title" required>
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea type="description" name="description" placeholder="Enter Description" required></textarea>
                </div>
                <div class="form-group">
                    <label class="upload-card">
                        <input
                            type="file"
                            multiple
                            accept=".jpg,.jpeg,.png,.webp"
                            name="images"
                            required
                            id="image-upload"
                        >

                        <div class="upload-content">
                            <div class="upload-icon">
                                <i class="bi bi-cloud-arrow-up"></i>
                            </div>

                            <h3>Upload Property Photos</h3>

                            <p>
                                Drag & drop your photos here or
                                <span>browse files</span>
                            </p>

                            <small>
                                JPG, PNG, WEBP • Multiple images allowed
                            </small>

                            <div id="file-count"></div>
                        </div>
                    </label>
                </div>
                <div class="form-group">
                    <label>Enter property type:</label>
                    <div class="property-grid">
                        <label class="property-card">
                            <input type="radio" name="propertyType" value="Hotel" id="hotel-btn" required>
                            <i class="bi bi-building"></i>
                            <span>Hotel</span>
                        </label>
                        <label class="property-card">
                            <input type="radio" name="propertyType" value="Apartment" id="apartment-btn">
                            <i class="bi bi-house-door"></i>
                            <span>Apartment</span>
                        </label>
                        <label class="property-card">
                            <input type="radio" name="propertyType" value="Villa" id="villa-btn">
                            <i class="bi bi-house-heart"></i>
                            <span>Villa</span>
                        </label>
                        <label class="property-card">
                            <input type="radio" name="propertyType" value="Homestay" id="homestay-btn">
                            <i class="bi bi-house"></i>
                            <span>Homestay</span>
                        </label>
                        <label class="property-card">
                            <input type="radio" name="propertyType" value="Hostel" id="hostel-btn">
                            <i class="bi bi-people"></i>
                            <span>Hostel</span>
                        </label>
                        <label class="property-card">
                            <input type="radio" name="propertyType" value="Resort" id="resort-btn">
                            <i class="bi bi-water"></i>
                            <span>Resort</span>
                        </label>
                        <label class="property-card">
                            <input type="radio" name="propertyType" value="Guest House" id="guest-house-btn">
                            <i class="bi bi-house-check"></i>
                            <span>Guest House</span>
                        </label>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <div class="section-header">
                    <i class="bi bi-door-open"></i>
                    <h2>Room Details</h2>
                </div>
                <div class="form-group">
                    <div class="room-types-container">
                        <div class="room-row">
                            <input type="hidden" name="roomTypes[0][roomType]" value="single-room">
                            <label>Single Room (1 person, 1 single bed)</label>
                            <input type="number" name="roomTypes[0][totalRooms]" min="0" placeholder="Available Rooms">
                            <input type="number" name="roomTypes[0][pricePerNight]" min="0" placeholder="Price / Night">
                        </div>
                        <div class="room-row">
                            <input type="hidden" name="roomTypes[1][roomType]" value="double-room">
                            <label>Double Room (2 person, 1 double bed)</label>
                            <input type="number" name="roomTypes[1][totalRooms]" min="0" placeholder="Available Rooms">
                            <input type="number" name="roomTypes[1][pricePerNight]" min="0" placeholder="Price / Night">
                        </div>
                        <div class="room-row">
                            <input type="hidden" name="roomTypes[2][roomType]" value="twin-room">
                            <label>Twin Room (2 person, 2 single bed)</label>
                            <input type="number" name="roomTypes[2][totalRooms]" min="0" placeholder="Available Rooms">
                            <input type="number" name="roomTypes[2][pricePerNight]" min="0" placeholder="Price / Night">
                        </div>
                        <div class="room-row">
                            <input type="hidden" name="roomTypes[3][roomType]" value="triple-room">
                            <label>Triple Room (3 person, 3 single bed or 1 double + 1 single)</label>
                            <input type="number" name="roomTypes[3][totalRooms]" min="0" placeholder="Available Rooms">
                            <input type="number" name="roomTypes[3][pricePerNight]" min="0" placeholder="Price / Night">
                        </div>
                        <div class="room-row">
                            <input type="hidden" name="roomTypes[4][roomType]" value="quad-room">
                            <label>Quad Room (4 person)</label>
                            <input type="number" name="roomTypes[4][totalRooms]" min="0" placeholder="Available Rooms">
                            <input type="number" name="roomTypes[4][pricePerNight]" min="0" placeholder="Price / Night">
                        </div>
                        <div class="room-row">
                            <input type="hidden" name="roomTypes[5][roomType]" value="queen-room">
                            <label>Queen Room</label>
                            <input type="number" name="roomTypes[5][totalRooms]" min="0" placeholder="Available Rooms">
                            <input type="number" name="roomTypes[5][pricePerNight]" min="0" placeholder="Price / Night">
                        </div>
                        <div class="room-row">
                            <input type="hidden" name="roomTypes[6][roomType]" value="king-room">
                            <label>King Room</label>
                            <input type="number" name="roomTypes[6][totalRooms]" min="0" placeholder="Available Rooms">
                            <input type="number" name="roomTypes[6][pricePerNight]" min="0" placeholder="Price / Night">
                        </div>
                        <div class="room-row">
                            <input type="hidden" name="roomTypes[7][roomType]" value="studio-room">
                            <label>Studio Room</label>
                            <input type="number" name="roomTypes[7][totalRooms]" min="0" placeholder="Available Rooms">
                            <input type="number" name="roomTypes[7][pricePerNight]" min="0" placeholder="Price / Night">
                        </div>
                        <div class="room-row">
                            <input type="hidden" name="roomTypes[8][roomType]" value="suite-room">
                            <label>Suite Room</label>
                            <input type="number" name="roomTypes[8][totalRooms]" min="0" placeholder="Available Rooms">
                            <input type="number" name="roomTypes[8][pricePerNight]" min="0" placeholder="Price / Night">
                        </div>
                        <div class="room-row">
                            <input type="hidden" name="roomTypes[9][roomType]" value="deluxe-room">
                            <label>Deluxe Room</label>
                            <input type="number" name="roomTypes[9][totalRooms]" min="0" placeholder="Available Rooms">
                            <input type="number" name="roomTypes[9][pricePerNight]" min="0" placeholder="Price / Night">
                        </div>
                        <div class="room-row">
                            <input type="hidden" name="roomTypes[10][roomType]" value="family-room">
                            <label>Family Room</label>
                            <input type="number" name="roomTypes[10][totalRooms]" min="0" placeholder="Available Rooms">
                            <input type="number" name="roomTypes[10][pricePerNight]" min="0" placeholder="Price / Night">
                        </div>
                        <div class="room-row">
                            <input type="hidden" name="roomTypes[11][roomType]" value="hostel-room">
                            <label>Dormitory / Hostel Room</label>
                            <input type="number" name="roomTypes[11][totalRooms]" min="0" placeholder="Available Rooms">
                            <input type="number" name="roomTypes[11][pricePerNight]" min="0" placeholder="Price / Night">
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="form-section">
                <div class="section-header">
                    <i class="bi bi-stars"></i>
                    <h2>Amenities</h2>
                </div>
                <div class="amenities-grid">
                    <label class="amenity-card">
                        <input type="checkbox" name="amenities[wifi]" value="true">
                        <i class="bi bi-wifi"></i>
                        <span>Wifi</span>
                    </label>
               
                    <label class="amenity-card">
                        <input type="checkbox" name="amenities[parking]" value="true">
                        <i class="bi bi-car-front-fill"></i>
                        <span>Parking</span>
                    </label>
                
                    <label class="amenity-card">
                        <input type="checkbox" name="amenities[spa]" value="true">
                        <i class="bi bi-flower1"></i>
                        <span>Spa</span>
                    </label>
                
                    <label class="amenity-card">
                        <input type="checkbox" name="amenities[pool]" value="true">
                        <i class="bi bi-water"></i>
                        <span>Pool</span>
                    </label>
                
                    <label class="amenity-card">
                        <input type="checkbox" name="amenities[gym]" value="true">
                        <i class="bi bi-activity"></i>
                        <span>Gym</span>
                    </label>
                
                    <label class="amenity-card">
                        <input type="checkbox" name="amenities[airconditioning]" value="true">
                        <i class="bi bi-snow"></i>
                        <span>Air Conditioning</span>
                    </label>
                
                    <label class="amenity-card">
                        <input type="checkbox" name="amenities[breakfast]" value="true">
                        <i class="bi bi-cup-hot"></i>
                        <span>Breakfast</span>
                    </label>
                
                    <label class="amenity-card">
                        <input type="checkbox" name="amenities[petFriendly]" value="true">
                        <i class="bi bi-heart"></i>
                        <span>Pet Friendly</span>
                    </label>
                
                    <label class="amenity-card">
                        <input type="checkbox" name="amenities[laundryService]" value="true">
                        <i class="bi bi-basket2"></i>
                        <span>Laundry Service</span>
                    </label>
                
                    <label class="amenity-card">
                        <input type="checkbox" name="amenities[restaurant]" value="true">
                        <i class="bi bi-shop"></i>
                        <span>Restaurant</span>
                    </label>
                
                    <label class="amenity-card">
                        <input type="checkbox" name="amenities[kitchen]" value="true">
                        <i class="bi bi-egg-fried"></i>
                        <span>Kitchen</span>
                    </label>
                
                    <label class="amenity-card">
                        <input type="checkbox" name="amenities[bar]" value="true">
                        <i class="bi bi-cup-straw"></i>
                        <span>Bar</span>
                    </label>
                
                    <label class="amenity-card">
                        <input type="checkbox" name="amenities[roomService]" value="true">
                        <i class="bi bi-bell"></i>
                        <span>Room Service</span>
                    </label>
                
                    <label class="amenity-card">
                        <input type="checkbox" name="amenities[frontDesk]" value="true">
                        <i class="bi bi-person-workspace"></i>
                        <span>Front Desk</span>
                    </label>
                </div>
            </div>

