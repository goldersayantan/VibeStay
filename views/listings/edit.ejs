<% layout("../layouts/boilerplate.ejs") %>
<link rel="stylesheet" href="/stylesheets/listings/edit.css">
<div class="form-container">
    <div class="form-card">
        <h2 class="form-title">Edit Your Property</h2>
        <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" enctype="multipart/form-data">
            <div class="form-group">
                <label>Property Title</label>
                <input placeholder="Enter property title" type="text" name="title" value="<%= listing.title %>" required>
            </div>
            <div class="form-group">
                <label>Description</label>
                <textarea placeholder="Enter the property description" name="description" id="description" required><%= listing.description %></textarea>
            </div>
            <h3 class="section-title">Current Images</h3>
            <div class="image-preview">
                <% listing.images.forEach((img) => { %>
                    <div class="image-box">
                    <img src="<%= img.url %>">
                    <label>
                        <input type="checkbox" name="deleteImages" value="<%= img.filename %>">
                        Delete
                    </label>
                    </div>
                <% }) %>
            </div>
            <div class="form-group">
                <label>Upload Images</label>
                <input type="file" multiple accept=".jpg, .png, .svg" name="images" id="property-photo">
            </div>
            <div class="form-group">
                <label>Enter Property Type</label>
                <label><input type="radio" name="propertyType" value="Hotel" id="hotel-btn" <%= listing.propertyType === "Hotel" ? "checked" : "" %> required>Hotel</label>
                <label><input type="radio" name="propertyType" value="Apartment" id="apartment-btn" <%= listing.propertyType === "Apartment" ? "checked" : "" %>>Apartment</label>
                <label><input type="radio" name="propertyType" value="Villa" id="villa-btn" <%= listing.propertyType === "Villa" ? "checked" : "" %>>Villa</label>
                <label><input type="radio" name="propertyType" value="Homestay" id="homestay-btn" <%= listing.propertyType === "Homestay" ? "checked" : "" %>>Homestay</label>
                <label><input type="radio" name="propertyType" value="Hostel" id="hostel-btn" <%= listing.propertyType === "Hostel" ? "checked" : "" %>>Hostel</label>
                <label><input type="radio" name="propertyType" value="Resort" id="resort-btn" <%= listing.propertyType === "Resort" ? "checked" : "" %>>Resort</label>
                <label><input type="radio" name="propertyType" value="Guest House" id="guest-house-btn" <%= listing.propertyType === "Guest House" ? "checked" : "" %>>Guest House</label>
            </div>
            <% const roomTypeList = ["single-room", "double-room", "twin-room", "triple-room", "quad-room", "queen-room", "king-room", "studio-room", "suite-room", "deluxe-room", "family-room", "hostel-room"]; %>
            <div class="room-types-container">
                <% roomTypeList.forEach((type, index) => {
                    const room = listing.roomTypes.find(r => r.roomType === type);
                %>

                    <div class="room-row">
                        <input type="hidden" name="roomTypes[<%= index %>][roomType]" value="<%= type %>">

                        <label><%= type.replace(/-/g, " ") %></label>

                        <input
                            type="number"
                            name="roomTypes[<%= index %>][totalRooms]"
                            value="<%= room ? room.totalRooms : 0 %>"
                            min="0"
                        >

                        <input
                            type="number"
                            name="roomTypes[<%= index %>][pricePerNight]"
                            value="<%= room ? room.pricePerNight : '' %>"
                            min="0"
                        >
                    </div>

                <% }) %>
            </div>
