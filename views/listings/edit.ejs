<% layout("../layouts/boilerplate.ejs") %>
<link rel="stylesheet" href="/stylesheets/listings/edit.css">
<div class="form-container">
    <div class="listing-header">
        <h1>Edit Your Stay</h1>
        <p>Update your property information and availability</p>
    </div>
    <div class="form-card">
        <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" enctype="multipart/form-data">           
            <div class="form-section">
                <div class="section-header">
                    <i class="bi bi-house-door"></i>
                    <h2>Basic Information</h2>
                </div>
                <div class="form-group">
                    <label>Property Title</label>
                    <input type="text" name="title" placeholder="Enter property title" value="<%= listing.title %>" required>
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea type="description" name="description" placeholder="Enter Description" required><%= listing.description %></textarea>
                </div>
 
                
                <div class="form-section">

                    <div class="section-header">
                        <i class="bi bi-images"></i>
                        <h2>Property Images</h2>
                    </div>

                    <div id="upload-flash" class="upload-flash"></div>

                    <!-- Existing Images -->
                    <div
                        id="existing-images"
                        class="image-preview-container"
                        data-existing-count="<%= listing.images.length %>"
                    >
                        <% listing.images.forEach((img) => { %>

                            <div
                                class="preview-card existing-image"
                                data-filename="<%= img.filename %>"
                            >

                                <img src="<%= img.url %>">

                                <button
                                    type="button"
                                    class="remove-existing-image"
                                >
                                    <i class="bi bi-x-lg"></i>
                                </button>

                                <input
                                    type="hidden"
                                    name="keepImages"
                                    value="<%= img.filename %>"
                                >

                            </div>

                        <% }) %>
                    </div>

                    <!-- New Upload -->
                    <label class="upload-card">

                        <input
                            type="file"
                            multiple
                            accept=".jpg,.jpeg,.png,.webp"
                            id="image-upload"
                            name="images"
                        >

                        <div class="upload-content">

                            <div class="upload-icon">
                                <i class="bi bi-cloud-arrow-up"></i>
                            </div>

                            <h3>Upload New Photos</h3>

                            <p>
                                Drag & drop your photos here or
                                <span>browse files</span>
                            </p>

                            <small>
                                Maximum 5 images total • 5MB each
                            </small>

                            <div id="file-count"></div>

                        </div>

                    </label>

                    <!-- New Image Preview -->
                    <div
                        id="image-preview-container"
                        class="image-preview-container"
                    ></div>

                    <!-- Hidden delete list -->
                    <div id="delete-images-container"></div>

                </div>


                <div class="form-group">
                    <label>Enter property type:</label>
                    <div class="property-grid">
                        <label class="property-card">
                            <input type="radio" name="propertyType" value="Hotel" id="hotel-btn" <%= listing.propertyType === "Hotel" ? "checked" : "" %> required>
                            <i class="bi bi-building"></i>
                            <span>Hotel</span>
                        </label>
                        <label class="property-card">
                            <input type="radio" name="propertyType" value="Apartment" id="apartment-btn" <%= listing.propertyType === "Apartment" ? "checked" : "" %>>
                            <i class="bi bi-house-door"></i>
                            <span>Apartment</span>
                        </label>
                        <label class="property-card">
                            <input type="radio" name="propertyType" value="Villa" id="villa-btn" <%= listing.propertyType === "Villa" ? "checked" : "" %>>
                            <i class="bi bi-house-heart"></i>
                            <span>Villa</span>
                        </label>
                        <label class="property-card">
                            <input type="radio" name="propertyType" value="Homestay" id="homestay-btn" <%= listing.propertyType === "Homestay" ? "checked" : "" %>>
                            <i class="bi bi-house"></i>
                            <span>Homestay</span>
                        </label>
                        <label class="property-card">
                            <input type="radio" name="propertyType" value="Hostel" id="hostel-btn" <%= listing.propertyType === "Hostel" ? "checked" : "" %>>
                            <i class="bi bi-people"></i>
                            <span>Hostel</span>
                        </label>
                        <label class="property-card">
                            <input type="radio" name="propertyType" value="Resort" id="resort-btn" <%= listing.propertyType === "Resort" ? "checked" : "" %>>
                            <i class="bi bi-water"></i>
                            <span>Resort</span>
                        </label>
                        <label class="property-card">
                            <input type="radio" name="propertyType" value="Guest House" id="guest-house-btn" <%= listing.propertyType === "Guest House" ? "checked" : "" %>>
                            <i class="bi bi-house-check"></i>
                            <span>Guest House</span>
                        </label>
                    </div>
                </div>
            </div>

            
            <%
            const roomData = {
                "single-room": {
                    title: "Single Room",
                    desc: "1 Person • 1 Single Bed"
                },
                "double-room": {
                    title: "Double Room",
                    desc: "2 Persons • 1 Double Bed"
                },
                "twin-room": {
                    title: "Twin Room",
                    desc: "2 Persons • 2 Single Beds"
                },
                "triple-room": {
                    title: "Triple Room",
                    desc: "3 Persons • 3 Single Beds or 1 Double + 1 Single"
                },
                "quad-room": {
                    title: "Quad Room",
                    desc: "4 Persons • Multiple Bed Configuration"
                },
                "queen-room": {
                    title: "Queen Room",
                    desc: "2 Persons • 1 Queen Bed"
                },
                "king-room": {
                    title: "King Room",
                    desc: "2 Persons • 1 King Bed"
                },
                "studio-room": {
                    title: "Studio Room",
                    desc: "2-3 Persons • Open Layout with Living Area"
                },
                "suite-room": {
                    title: "Suite Room",
                    desc: "2-4 Persons • Separate Living & Sleeping Areas"
                },
                "deluxe-room": {
                    title: "Deluxe Room",
                    desc: "2-3 Persons • Premium Room with Extra Amenities"
                },
                "family-room": {
                    title: "Family Room",
                    desc: "4-6 Persons • Designed for Families"
                },
                "hostel-room": {
                    title: "Dormitory / Hostel Room",
                    desc: "4-12 Persons • Shared Sleeping Space"
                }
            };

            const roomTypeList = Object.keys(roomData);
            %>

            <div class="form-section">
                <div class="section-header">
                    <i class="bi bi-door-open"></i>
                    <h2>Room Details</h2>
                </div>
                <div class="form-group">
                    <div class="room-grid">
                        <% roomTypeList.forEach((type, index) => {
                            const room = listing.roomTypes.find(
                                r => r.roomType === type
                            );
                        %>
                            <div class="room-card">
                                <input
                                    type="hidden"
                                    name="roomTypes[<%= index %>][roomType]"
                                    value="<%= type %>"
                                >
                                <div class="room-header">
                                    <i class="bi bi-door-open"></i>
                                    <div>
                                        <h3>
                                            <%= roomData[type].title %>
                                        </h3>
                                        <p>
                                            <%= roomData[type].desc %>
                                        </p>
                                    </div>
                                </div>
                                <div class="room-inputs">
                                    <div class="room-field">
                                        <label>
                                            Available Rooms
                                        </label>
                                        <input
                                            type="number"
                                            name="roomTypes[<%= index %>][totalRooms]"
                                            value="<%= room ? room.totalRooms : 0 %>"
                                            min="0"
                                        >
                                    </div>
                                    <div class="room-field">
                                        <label>
                                            Price / Night
                                        </label>
                                        <input
                                            type="number"
                                            name="roomTypes[<%= index %>][pricePerNight]"
                                            value="<%= room ? room.pricePerNight : '' %>"
                                            min="0"
                                        >
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>
            
            <div class="form-section">
                <div class="section-header">
                    <i class="bi bi-stars"></i>
                    <h2>Amenities</h2>
                </div>
                <div class="amenities-grid">
                    <label class="amenity-card">
                        <input type="checkbox" name="amenities[wifi]" value="true" <%= listing.amenities?.wifi ? "checked" : "" %>>
                        <i class="bi bi-wifi"></i>
                        <span>Wifi</span>
                    </label>
               
                    <label class="amenity-card">
