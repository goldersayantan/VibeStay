                        <i class="bi bi-basket2"></i>
                        <span>Laundry Service</span>
                    </label>
                
                    <label class="amenity-card">
                        <input type="checkbox" name="amenities[restaurant]" value="true" <%= listing.amenities?.restaurant ? "checked" : "" %>>
                        <i class="bi bi-shop"></i>
                        <span>Restaurant</span>
                    </label>
                
                    <label class="amenity-card">
                        <input type="checkbox" name="amenities[kitchen]" value="true" <%= listing.amenities?.kitchen ? "checked" : "" %>>
                        <i class="bi bi-egg-fried"></i>
                        <span>Kitchen</span>
                    </label>
                
                    <label class="amenity-card">
                        <input type="checkbox" name="amenities[bar]" value="true" <%= listing.amenities?.bar ? "checked" : "" %>>
                        <i class="bi bi-cup-straw"></i>
                        <span>Bar</span>
                    </label>
                
                    <label class="amenity-card">
                        <input type="checkbox" name="amenities[roomService]" value="true" <%= listing.amenities?.roomService ? "checked" : "" %>>
                        <i class="bi bi-bell"></i>
                        <span>Room Service</span>
                    </label>
                
                    <label class="amenity-card">
                        <input type="checkbox" name="amenities[frontDesk]" value="true" <%= listing.amenities?.frontDesk ? "checked" : "" %>>
                        <i class="bi bi-person-workspace"></i>
                        <span>Front Desk</span>
                    </label>
                </div>
            </div>

