<% layout("../layouts/boilerplate.ejs") %>
<link rel="stylesheet" href="/stylesheets/pages/cancellation-policy.css">

<div class="policy-page">
    <div class="policy-container">
        <div class="page-header">
            <i class="bi bi-calendar-x"></i>
            <h1>Cancellation Policy</h1>
            <p>Please review our cancellation guidelines before making a booking. Understanding the policy helps ensure a smooth experience for both guests and hosts.</p>
        </div>

        <section class="policy-section">
            <div class="section-title">
                <i class="bi bi-person-check"></i>
                <h2>Guest Cancellations</h2>
            </div>

            <div class="policy-item">
                <h4>Before Approval</h4>
                <p>Guests may cancel a booking request at any time before it has been approved by the host.</p>
            </div>

            <div class="policy-item">
                <h4>Approved Bookings</h4>
                <p>Approved bookings can be cancelled up to 24 hours before the scheduled check-in date.</p>
            </div>

            <div class="policy-item">
                <h4>Late Cancellations</h4>
                <p>Cancellation requests made within 24 hours of check-in may not be eligible for refunds or approval.</p>
            </div>
        </section>

        <section class="policy-section">
            <div class="section-title">
                <i class="bi bi-house-door"></i>
                <h2>Host Responsibilities</h2>
            </div>

            <div class="policy-item">
                <h4>Accurate Availability</h4>
                <p>Hosts should keep room availability updated to avoid unnecessary booking cancellations.</p>
            </div>

            <div class="policy-item">
                <h4>Booking Decisions</h4>
                <p>Hosts should review and respond to booking requests promptly to provide a better guest experience.</p>
            </div>

            <div class="policy-item">
                <h4>Exceptional Circumstances</h4>
                <p>In rare situations involving safety concerns, property issues, or emergencies, bookings may be cancelled by the host.</p>
            </div>
        </section>

        <section class="policy-section">
            <div class="section-title">
                <i class="bi bi-exclamation-circle"></i>
                <h2>Important Notes</h2>
            </div>

            <div class="policy-item">
                <h4>Policy Changes</h4>
                <p>VibeStay reserves the right to modify cancellation policies when necessary to improve platform operations.</p>
            </div>

            <div class="policy-item">
                <h4>Support Assistance</h4>
                <p>If you experience issues regarding a cancellation, please contact our support team for assistance.</p>
            </div>

            <div class="policy-item">
                <h4>Terms Compliance</h4>
                <p>All cancellations must comply with VibeStay's Terms of Service and community guidelines.</p>
            </div>
        </section>
    </div>
</div>
