<% layout("../layouts/boilerplate.ejs") %>
<link rel="stylesheet" href="/stylesheets/pages/trust-safety.css">

<div class="info-page">
    <div class="info-container">
        <div class="page-header">
            <i class="bi bi-shield-fill-check"></i>
            <h1>Trust & Safety</h1>
            <p>
                Creating a secure, respectful, and reliable environment for
                guests and hosts is one of VibeStay's highest priorities.
            </p>
        </div>

        <section class="info-section">
            <h2>
                <i class="bi bi-person-check-fill"></i>
                Verified Community
            </h2>

            <p>
                We encourage hosts and guests to provide accurate account
                information. Maintaining trustworthy profiles helps create
                a safer experience for everyone on the platform.
            </p>
        </section>

        <section class="info-section">
            <h2>
                <i class="bi bi-house-check-fill"></i>
                Safe Booking Practices
            </h2>

            <ul>
                <li>Review property details carefully before booking.</li>
                <li>Read listing descriptions and policies thoroughly.</li>
                <li>Communicate clearly with hosts regarding expectations.</li>
                <li>Verify travel dates before submitting booking requests.</li>
                <li>Report suspicious listings immediately.</li>
            </ul>
        </section>

        <section class="info-section">
            <h2>
                <i class="bi bi-shield-lock-fill"></i>
                Account Security
            </h2>

            <p>
                Protect your account by using strong passwords and keeping
                login credentials private. Never share your account details
                with others.
            </p>

            <div class="safety-note">
                <i class="bi bi-lock-fill"></i>
                <span>
                    Always use a unique password and keep your login information confidential.
                </span>
            </div>
        </section>

        <section class="info-section">
            <h2>
                <i class="bi bi-flag-fill"></i>
                Reporting Concerns
            </h2>

            <p>
                If you encounter suspicious behavior, fraudulent activity,
                inaccurate property information, or violations of community
                standards, please contact our support team immediately.
            </p>
        </section>

        <section class="info-section">
            <h2>
                <i class="bi bi-people-fill"></i>
                Respectful Community Standards
            </h2>

            <ul>
                <li>Treat guests and hosts with respect.</li>
                <li>Provide honest and accurate information.</li>
                <li>Avoid harassment, discrimination, or abusive behavior.</li>
                <li>Follow property rules and local regulations.</li>
                <li>Maintain professional communication.</li>
            </ul>
        </section>

        <section class="info-section">
            <h2>
                <i class="bi bi-exclamation-triangle-fill"></i>
                Fraud Prevention
            </h2>

            <p>
                Be cautious of unusual requests, suspicious messages,
                or attempts to obtain personal information. Report any
                activity that appears fraudulent or unsafe.
            </p>
        </section>

        <section class="info-section">
            <h2>
                <i class="bi bi-heart-pulse-fill"></i>
                Emergency Situations
            </h2>

            <p>
                In case of an emergency, contact local emergency services
                immediately. After ensuring your safety, notify the VibeStay
                support team regarding the incident.
            </p>
        </section>

        <section class="info-section">
            <h2>
                <i class="bi bi-shield-fill"></i>
                Our Commitment
            </h2>

            <p>
                VibeStay continuously works to improve platform safety,
                strengthen security measures, and provide a trusted
                experience for every member of our community.
            </p>
        </section>
    </div>
</div>