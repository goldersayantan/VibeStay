<% layout("../layouts/boilerplate.ejs") %>
<link rel="stylesheet" href="/stylesheets/pages/privacy-policy.css">

<div class="info-page">
    <div class="info-container">
        <div class="page-header">
            <i class="bi bi-shield-lock-fill"></i>
            <h1>Privacy Policy</h1>
            <p>
                Your privacy is important to us. This policy explains how
                VibeStay collects, uses, stores, and protects your information.
            </p>
        </div>

        <section class="info-section">
            <h2>
                <i class="bi bi-database-fill"></i>
                Information We Collect
            </h2>
            <p>When you use VibeStay, we may collect information such as:</p>
            <ul>
                <li>Name and username.</li>
                <li>Email address.</li>
                <li>Profile information.</li>
                <li>Booking and reservation details.</li>
                <li>Property listing information.</li>
                <li>Location-related data provided by users.</li>
            </ul>
        </section>

        <section class="info-section">
            <h2>
                <i class="bi bi-gear-fill"></i>
                How We Use Your Information
            </h2>

            <ul>
                <li>Provide and improve our services.</li>
                <li>Process bookings and reservations.</li>
                <li>Enable communication between hosts and guests.</li>
                <li>Send important account notifications.</li>
                <li>Maintain platform security and prevent abuse.</li>
                <li>Enhance user experience and performance.</li>
            </ul>
        </section>

        <section class="info-section">
            <h2>
                <i class="bi bi-lock-fill"></i>
                Data Security
            </h2>
            <p>
                We implement reasonable security measures to protect user
                information from unauthorized access, misuse, alteration,
                or disclosure. However, no online platform can guarantee
                absolute security.
            </p>

            <div class="privacy-note">
                <i class="bi bi-shield-check"></i>
                <span>
                    We continuously work to keep your information safe and secure.
                </span>
            </div>
        </section>

        <section class="info-section">
            <h2>
                <i class="bi bi-share-fill"></i>
                Information Sharing
            </h2>
            <p>
                VibeStay does not sell your personal information. Information
                may only be shared when necessary to:
            </p>

            <ul>
                <li>Complete booking transactions.</li>
                <li>Comply with legal obligations.</li>
                <li>Protect platform security and users.</li>
                <li>Provide essential platform functionality.</li>
            </ul>
        </section>

        <section class="info-section">
            <h2>
                <i class="bi bi-person-check-fill"></i>
                Your Rights
            </h2>

            <ul>
                <li>Access your personal information.</li>
                <li>Update or correct profile details.</li>
                <li>Request account deletion where applicable.</li>
                <li>Manage your account preferences.</li>
            </ul>
        </section>

        <section class="info-section">
            <h2>
                <i class="bi bi-cookie"></i>
                Cookies & Analytics
            </h2>

            <p>
                We may use cookies and similar technologies to improve site
                performance, remember preferences, and analyze usage trends.
            </p>
        </section>

        <section class="info-section">
            <h2>
                <i class="bi bi-arrow-repeat"></i>
                Policy Updates
            </h2>

            <p>
                This Privacy Policy may be updated periodically. Continued use
                of the platform after updates indicates acceptance of the
                revised policy.
            </p>
        </section>

        <section class="info-section">
            <h2>
                <i class="bi bi-envelope-fill"></i>
                Contact Us
            </h2>

            <p>
                If you have questions regarding this Privacy Policy, please
                contact the VibeStay support team through our Contact page.
            </p>
        </section>
    </div>
</div>