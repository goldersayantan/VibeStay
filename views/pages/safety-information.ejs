<% layout("../layouts/boilerplate.ejs") %>
<link rel="stylesheet" href="/stylesheets/pages/safety-information.css">

<div class="safety-page">
    <div class="safety-container">
        <div class="page-header">
            <i class="bi bi-shield-check"></i>
            <h1>Safety Information</h1>
            <p>Your safety is important to us. Please review these guidelines to ensure a secure and enjoyable experience on VibeStay.</p>
        </div>

        <section class="safety-section">
            <div class="section-title">
                <i class="bi bi-person-check"></i>
                <h2>For Guests</h2>
            </div>

            <div class="safety-item">
                <h4>Verify Property Details</h4>
                <p>Carefully review listing photos, descriptions, amenities, and reviews before making a booking request.</p>
            </div>

            <div class="safety-item">
                <h4>Communicate Through VibeStay</h4>
                <p>Keep all booking-related communication within the platform whenever possible.</p>
            </div>

            <div class="safety-item">
                <h4>Report Suspicious Activity</h4>
                <p>Immediately report listings, messages, or users that appear fraudulent or suspicious.</p>
            </div>
        </section>

        <section class="safety-section">
            <div class="section-title">
                <i class="bi bi-house-lock"></i>
                <h2>For Hosts</h2>
            </div>

            <div class="safety-item">
                <h4>Maintain Accurate Listings</h4>
                <p>Ensure that property information, pricing, room availability, and amenities remain up to date.</p>
            </div>

            <div class="safety-item">
                <h4>Screen Booking Requests</h4>
                <p>Review booking details carefully before approving reservations.</p>
            </div>

            <div class="safety-item">
                <h4>Provide Emergency Contacts</h4>
                <p>Keep local emergency contact information readily available for guests when needed.</p>
            </div>
        </section>

        <section class="safety-section">
            <div class="section-title">
                <i class="bi bi-exclamation-triangle"></i>
                <h2>General Safety Tips</h2>
            </div>

            <div class="safety-item">
                <h4>Protect Personal Information</h4>
                <p>Never share passwords, OTPs, payment credentials, or sensitive personal information with anyone.</p>
            </div>

            <div class="safety-item">
                <h4>Use Secure Networks</h4>
                <p>Access your account through trusted devices and secure internet connections.</p>
            </div>

            <div class="safety-item">
                <h4>Stay Alert</h4>
                <p>If something feels unusual or unsafe, trust your judgment and contact support immediately.</p>
            </div>
        </section>
    </div>
</div>
