<% layout("../layouts/boilerplate.ejs") %>
<link rel="stylesheet" href="/stylesheets/pages/help-center.css">

<div class="help-center-page">
    <div class="help-container">

        <div class="page-header">
            <i class="bi bi-life-preserver"></i>
            <h1>Help Center</h1>
            <p>Find answers to common questions and get support for your VibeStay experience.</p>
        </div>

        <section class="help-section">
            <div class="section-title">
                <i class="bi bi-search"></i>
                <h2>Finding a Stay</h2>
            </div>

            <div class="help-item">
                <h4>How do I search for properties?</h4>
                <p>
                    Use the search bar on the homepage to browse listings by destination,
                    property type, and availability.
                </p>
            </div>

            <div class="help-item">
                <h4>Can I filter search results?</h4>
                <p>
                    Yes. You can filter listings by country, city, price range,
                    amenities, and property type.
                </p>
            </div>
        </section>

        <section class="help-section">
            <div class="section-title">
                <i class="bi bi-calendar-check"></i>
                <h2>Bookings</h2>
            </div>

            <div class="help-item">
                <h4>How do bookings work?</h4>
                <p>
                    Submit a booking request and wait for the host to approve it.
                    Once approved, your reservation will be confirmed.
                </p>
            </div>

            <div class="help-item">
                <h4>Can I cancel a booking?</h4>
                <p>
                    Bookings can be cancelled before the property's cancellation
                    deadline. Availability depends on the host's policies.
                </p>
            </div>
        </section>

        <section class="help-section">
            <div class="section-title">
                <i class="bi bi-house-door"></i>
                <h2>Hosting</h2>
            </div>

            <div class="help-item">
                <h4>How do I list my property?</h4>
                <p>
                    Create an account, add your property details, upload photos,
                    configure rooms and pricing, then publish your listing.
                </p>
            </div>

            <div class="help-item">
                <h4>How do I manage booking requests?</h4>
                <p>
                    Visit your dashboard to approve, reject, or monitor booking requests.
                </p>
            </div>
        </section>

        <section class="help-section">
            <div class="section-title">
                <i class="bi bi-shield-check"></i>
                <h2>Account & Security</h2>
            </div>

            <div class="help-item">
                <h4>How do I reset my password?</h4>
                <p>
                    Use the "Forgot Password" option on the login page and follow
                    the OTP verification process.
                </p>
            </div>

            <div class="help-item">
                <h4>Is my information secure?</h4>
                <p>
                    We use industry-standard security practices to protect your account
                    and personal information.
                </p>
            </div>
        </section>
    </div>
</div>