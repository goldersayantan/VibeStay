<% layout("../layouts/boilerplate.ejs") %>
<link rel="stylesheet" href="/stylesheets/pages/about-us.css">
<div class="info-page">
    <div class="info-container">
        <div class="page-header">
            <i class="bi bi-buildings-fill"></i>
            <h1>About VibeStay</h1>
            <p>Your trusted platform for discovering unique stays and unforgettable travel experiences.</p>
        </div>

        <section class="info-section">
            <h2><i class="bi bi-stars"></i> Our Mission</h2>
            <p>
                At VibeStay, our mission is simple: connect travelers with
                comfortable, affordable, and memorable accommodations around
                the world. We believe every trip deserves a place that feels
                welcoming, secure, and inspiring.
            </p>
        </section>

        <section class="info-section">
            <h2><i class="bi bi-globe2"></i> What We Do</h2>
            <p>
                VibeStay helps guests discover hotels, apartments, villas,
                homestays, hostels, resorts, and guest houses while providing
                hosts with powerful tools to showcase their properties and
                manage bookings efficiently.
            </p>

            <div class="feature-grid">
                <div class="feature-card">
                    <i class="bi bi-search"></i>
                    <h3>Easy Discovery</h3>
                    <p>Find accommodations that match your preferences and budget.</p>
                </div>

                <div class="feature-card">
                    <i class="bi bi-calendar-check"></i>
                    <h3>Simple Booking</h3>
                    <p>Quick booking requests with transparent pricing.</p>
                </div>

                <div class="feature-card">
                    <i class="bi bi-house-check"></i>
                    <h3>Host Management</h3>
                    <p>Tools for hosts to manage listings and reservations.</p>
                </div>

                <div class="feature-card">
                    <i class="bi bi-shield-check"></i>
                    <h3>Safe Experience</h3>
                    <p>Focused on trust, security, and responsible hosting.</p>
                </div>
            </div>
        </section>

        <section class="info-section">
            <h2><i class="bi bi-people-fill"></i> Our Community</h2>
            <p>
                VibeStay is built around a growing community of travelers and
                hosts who share a passion for hospitality. Every booking helps
                create meaningful connections between people and places.
            </p>
        </section>

        <section class="info-section">
            <h2><i class="bi bi-lightbulb-fill"></i> Our Vision</h2>
            <p>
                We envision a world where finding the perfect stay is effortless.
                By combining technology, trust, and hospitality, we aim to make
                travel planning simpler and more enjoyable for everyone.
            </p>
        </section>

        <section class="info-section">
            <h2><i class="bi bi-heart-fill"></i> Thank You</h2>
            <p>
                Whether you're exploring a new destination or welcoming guests
                into your property, thank you for being part of the VibeStay
                journey. Together, we're creating better travel experiences.
            </p>
        </section>
    </div>
</div>