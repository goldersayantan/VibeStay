<% layout("../layouts/boilerplate.ejs") %>
<link rel="stylesheet" href="/stylesheets/pages/community-forum.css">

<div class="info-page">
    <div class="info-container">
        <div class="page-header">
            <i class="bi bi-people-fill"></i>
            <h1>Community Forum</h1>
            <p>
                Connect with fellow hosts and travelers, share experiences,
                exchange ideas, and learn from the VibeStay community.
            </p>
        </div>

        <section class="info-section">
            <h2>
                <i class="bi bi-chat-dots-fill"></i>
                Join Discussions
            </h2>
            <p>
                Participate in conversations about hosting, travel experiences,
                guest management, property improvements, and industry trends.
            </p>
        </section>

        <section class="info-section">
            <h2>
                <i class="bi bi-lightbulb-fill"></i>
                Share Tips & Advice
            </h2>
            <p>
                Learn practical hosting strategies from experienced hosts and
                help newcomers by sharing your own knowledge and best practices.
            </p>

            <div class="forum-card">
                <i class="bi bi-star-fill"></i>
                <span>Great hosts learn from great communities.</span>
            </div>
        </section>

        <section class="info-section">
            <h2>
                <i class="bi bi-house-heart-fill"></i>
                Hosting Discussions
            </h2>
            <ul>
                <li>Property management tips.</li>
                <li>Guest communication strategies.</li>
                <li>Pricing and occupancy advice.</li>
                <li>Review and reputation management.</li>
                <li>Local hosting regulations.</li>
            </ul>
        </section>

        <section class="info-section">
            <h2>
                <i class="bi bi-airplane-fill"></i>
                Traveler Discussions
            </h2>
            <p>
                Travelers can exchange destination recommendations, accommodation
                suggestions, travel itineraries, and local experiences.
            </p>
        </section>

        <section class="info-section">
            <h2>
                <i class="bi bi-shield-check"></i>
                Community Guidelines
            </h2>
            <ul>
                <li>Respect all community members.</li>
                <li>Share accurate and helpful information.</li>
                <li>Avoid spam or promotional content.</li>
                <li>Maintain a friendly and professional tone.</li>
                <li>Report inappropriate behavior when necessary.</li>
            </ul>
        </section>

        <section class="info-section">
            <h2>
                <i class="bi bi-trophy-fill"></i>
                Benefits of Participation
            </h2>
            <p>
                Active community members gain valuable insights, discover new
                opportunities, build relationships, and stay updated with the
                latest hosting and travel trends.
            </p>
        </section>
    </div>
</div>