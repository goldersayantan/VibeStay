<% layout("../layouts/boilerplate.ejs") %>
<link rel="stylesheet" href="/stylesheets/user/signup.css">
<div class="signUp-container">
    <div class="signup-wrapper">
        <div class="signup-left">

            <img
                src="/VibeStayLogo.png"
                alt="VibeStay"
                class="signup-logo"
            >

            <h1>Stays that match your vibe.</h1>

            <p>
                Discover unique homes, luxury villas,
                apartments and unforgettable stays
                around the world.
            </p>

            <div class="signup-features">
                <span>✓ Verified Hosts</span>
                <span>✓ Secure Booking</span>
                <span>✓ Unique Experiences</span>
            </div>

        </div>

        <div class="signUp-card">

            <h2>Create Account</h2>

            <p class="signup-subtitle">
                Join VibeStay today.
            </p>

            <form action="/signUp" method="POST">

                <label>
                    Username
                    <input type="text" id="username" name="username" required>
                </label>

                <label>
                    Email
                    <input type="email" id="email" name="email" required>
                </label>

                <label>
                    Password
                    <input type="password" id="password" name="password" required>

                    <small id="password-message">
                        8+ characters, uppercase, lowercase,
                        number and special character
                    </small>
                </label>

                <label>
                    Confirm Password
                    <input
                        type="password"
                        id="confirm-password"
                        name="confirm-password"
                        required
                    >
                </label>

                <button
                    type="submit"
                    class="signUp-btn"
                >
                    Send OTP
                </button>

                <div class="divider">
                    or
                </div>

                <a href="/auth/google" class="google-btn">
                    Continue with Google
                </a>

                <a href="/signin" class="signIn">
                    Already have an account?
                    <span>Sign In</span>
                </a>

            </form>

        </div>

    </div>

    

</div>
<script src="/scripts/user/signup.js"></script>
